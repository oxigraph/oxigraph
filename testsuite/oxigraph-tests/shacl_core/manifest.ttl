@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix mf:    <http://www.w3.org/2001/sw/DataAccess/tests/test-manifest#> .
@prefix :      <https://github.com/oxigraph/oxigraph/tests/shacl_core/manifest#> .
@prefix ox:    <https://github.com/oxigraph/oxigraph/tests#> .

<>  rdf:type mf:Manifest ;
    rdfs:label "Oxigraph SHACL Core validation tests" ;
    rdfs:comment "Validation tests for oxreason's SHACL Core validator. Each entry loads a combined shapes-plus-data graph (mf:action), runs Validator::validate, and asserts that every (focus, constraint) pair in the expected graph (mf:result) is present as a violation in the report." ;
    mf:entries
    (
        :min_count_violation
    ) .

:min_count_violation rdf:type ox:ShaclValidationTest ;
    mf:name "sh:minCount on a target class flags missing values" ;
    mf:action <min_count.action.ttl> ;
    mf:result <min_count.expected.ttl> .
