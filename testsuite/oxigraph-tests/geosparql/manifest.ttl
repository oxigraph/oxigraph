    mf:action [ qt:query <union.rq> ] ;
    mf:result <union.srx> .

:difference rdf:type mf:QueryEvaluationTest ;
    mf:name "difference of two overlapping squares" ;
    mf:feature geof:difference ;
    mf:action [ qt:query <difference.rq> ] ;
    mf:result <difference.srx> .

:sym_difference rdf:type mf:QueryEvaluationTest ;
    mf:name "symDifference of two overlapping squares" ;
    mf:feature geof:symDifference ;
    mf:action [ qt:query <sym_difference.rq> ] ;
    mf:result <sym_difference.srx> .

:area rdf:type mf:QueryEvaluationTest ;
    mf:name "area of unit-edge polygon within tolerance" ;
    mf:feature geof:area ;
    mf:action [ qt:query <area.rq> ] ;
    mf:result <area.srx> .

:distance rdf:type mf:QueryEvaluationTest ;
    mf:name "distance between two points within tolerance" ;
