PREFIX geo: <http://www.opengis.net/ont/geosparql#>
PREFIX geof: <http://www.opengis.net/def/function/geosparql/>

SELECT ?left ?right (geof:ehDisjoint(?left, ?right) AS ?result) WHERE {
    VALUES (?left ?right) {
        ("Polygon((0 0, 1 0, 1 1, 0 1, 0 0))"^^geo:wktLiteral "Polygon((5 5, 6 5, 6 6, 5 6, 5 5))"^^geo:wktLiteral)
        ("Polygon((0 0, 2 0, 2 2, 0 2, 0 0))"^^geo:wktLiteral "Polygon((1 1, 3 1, 3 3, 1 3, 1 1))"^^geo:wktLiteral)
    }
}
