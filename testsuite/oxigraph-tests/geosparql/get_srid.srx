<?xml version="1.0"?>
<sparql xmlns="http://www.w3.org/2005/sparql-results#">
    <head>
        <variable name="geom"/>
        <variable name="result"/>
    </head>
    <results>
        <result>
            <binding name="geom">
                <literal datatype="http://www.opengis.net/ont/geosparql#wktLiteral">Point(10 20)</literal>
            </binding>
            <binding name="result">
                <literal datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://www.opengis.net/def/crs/OGC/1.3/CRS84</literal>
            </binding>
        </result>
    </results>
</sparql>
