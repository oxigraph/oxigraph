PREFIX schema: <http://schema.org/>
PREFIX ex: <http://example.org/>
SELECT * WHERE {
  ?c a schema:Person ;
     schema:addressCountry ?country ;
     ex:segment ?segment .
  LATERAL { VALUES () { () } OPTIONAL {
    ?order schema:customer ?c ;
           a schema:Order ;
           schema:totalPrice ?total .
  } }
}
